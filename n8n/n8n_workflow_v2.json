  "connections": {
    "Webhook": {
      "main": [[
        { "node": "Route by event_type", "type": "main", "index": 0 }
      ]]
    },
    "Route by event_type": {
      "main": [
        [{ "node": "Crowd Alert",              "type": "main", "index": 0 }],
        [{ "node": "Parking Alert",            "type": "main", "index": 0 }],
        [{ "node": "Violence Alert — Initial", "type": "main", "index": 0 }]
      ]
