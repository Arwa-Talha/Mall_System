      ]]
    },
    "Escalated Alert": {
      "main": [[
        { "node": "Wait Again (30s)", "type": "main", "index": 0 }
      ]]
    },
    "Wait Again (30s)": {
      "main": [[
        { "node": "Check ACK (Escalated)", "type": "main", "index": 0 }
      ]]
    },
    "Check ACK (Escalated)": {
      "main": [[
        { "node": "Acknowledged? (Escalated)", "type": "main", "index": 0 }
      ]]
    },
    "Acknowledged? (Escalated)": {
      "main": [
        [{ "node": "Notify Resolved (Escalated)", "type": "main", "index": 0 }],
        [{ "node": "Max Escalation Reached",      "type": "main", "index": 0 }]
      ]
    }
  },

  "active": true,
  "settings": {
    "executionOrder": "v1",
    "binaryMode": "separate",
    "availableInMCP": false
  },

  "meta": {
    "templateCredsSetupCompleted": true,
    "instanceId": "de344202fea41d3aa93f587030b8f67ecad00e5c56215ea2fa86623089b9866d",
    "notes": [
      "Switch node routes heartbeat→Crowd, state_change→Parking, violence_alert→Violence escalation chain.",
      "executeOnce has been removed from all Telegram nodes.",
      "Violence path: Initial alert → Wait 30s → Check ACK → if not acked → Get Next Guard → Escalated alert → Wait 30s → Check ACK → if still not acked → Max Escalation message.",
      "To add more escalation loops, duplicate the Get Next Guard → Escalated Alert → Wait → Check ACK → IF chain and connect the NO branch of each IF to the next loop.",
      "Guard chat_ids in the dispatch block come from /api/v1/guards/next on the gateway.",
      "Telegram inline-keyboard ACCEPT button callback_data format: 'ack:{incident_id}:{guard_id}' — wire a Telegram Trigger node to catch this and POST to /api/v1/acknowledge."
    ]
  }
}
