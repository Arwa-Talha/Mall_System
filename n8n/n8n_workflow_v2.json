    {
      "parameters": {
        "chatId": "1708697158",
        "text": "=🅿️ *Smart Mall — Parking Monitor*\n\n▪️ Source: {{ $json.body.source }}\n▪️ Event: {{ $json.body.event_type }}\n▪️ Mall: {{ $json.body.mall_id }}\n▪️ Camera: {{ $json.body.camera_id }}\n▪️ Occupied: {{ $json.body.data.occupied_count }} / {{ $json.body.data.total_spots }}\n▪️ Free Spots: {{ $json.body.data.free_count }}\n\n⚠️ Severity: {{ $json.body.severity }}\n🕒 {{ $json.body.timestamp }}",
        "additionalFields": { "parse_mode": "Markdown" }
