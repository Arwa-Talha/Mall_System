    {
      "parameters": {
        "chatId": "1708697158",
        "text": "=✅ *Incident Resolved (after escalation)*\n\nIncident `{{ $('Route by event_type').item.json.body.incident_id }}` acknowledged at escalation level {{ $json.escalation_level }}.",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [2240, 200],
      "id": "telegram-resolved-escalated",
      "name": "Notify Resolved (Escalated)",
      "credentials": {
        "telegramApi": {
          "id": "mPA3YoRTS25g98lE",
          "name": "Telegram account"
        }
      }
    },

    {
      "parameters": {
        "chatId": "1708697158",
        "text": "=🆘 *UNACKNOWLEDGED INCIDENT — Manual Intervention Required*\n\nAll {{ $('Route by event_type').item.json.body.dispatch.max_escalation_level }} escalation levels exhausted.\n\n🆔 Incident: `{{ $('Route by event_type').item.json.body.incident_id }}`\n📍 {{ $('Route by event_type').item.json.body.source.mall_id }} | {{ $('Route by event_type').item.json.body.source.camera_id }}\n\nPlease respond immediately.",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [2240, 480],
      "id": "telegram-max-escalation",
      "name": "Max Escalation Reached",
      "credentials": {
        "telegramApi": {
          "id": "mPA3YoRTS25g98lE",
          "name": "Telegram account"
        }
      }
    },

    {
      "parameters": {
        "chatId": "1708697158",
        "text": "=🏢 *Smart Mall — Crowd Monitor*\n\n▪️ Source: {{ $json.body.source }}\n▪️ Event: {{ $json.body.event_type }}\n▪️ Mall: {{ $json.body.mall_id }}\n▪️ Camera: {{ $json.body.camera_id }}\n▪️ Crowd Level: {{ $json.body.data.level }}\n▪️ People Count: {{ $json.body.data.count }}\n\n⚙️ Auto-Adjusted Systems:\nLighting: {{ $json.body.data.lighting }}\nHVAC: {{ $json.body.data.hvac }}\n\n⚠️ Severity: {{ $json.body.severity }}\n🕒 {{ $json.body.timestamp }}",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [80, -160],
      "id": "telegram-crowd",
      "name": "Crowd Alert",
      "credentials": {
        "telegramApi": {
          "id": "mPA3YoRTS25g98lE",
